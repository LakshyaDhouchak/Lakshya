   "source": [
    "from langchain_community.document_loaders import DirectoryLoader, PyPDFLoader\n",
    "\n",
    "loader = DirectoryLoader(\n",
    "    path = 'books',\n",
    "    glob = '*.pdf',\n",
    "    loader_cls= PyPDFLoader\n",
    ")\n",
    "\n",
    "docs = loader.lazy_load();\n",
    "print(len(docs))"
   ]
  }
